<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Alex Perronnet — portfolio under construction." />
		<meta name="theme-color" content="#efeae0" />
		<title>Alex Perronnet — Under Construction</title>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap"
			rel="stylesheet"
		/>

		<style>
			:root {
				--bg: #efeae0;
				--ink: #15201a;
				--ink-soft: rgba(21, 32, 26, 0.55);
				--ink-faint: rgba(21, 32, 26, 0.28);
				--rule: rgba(21, 32, 26, 0.16);
				--accent: #c8462a;
				--mono: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
				--serif: "Instrument Serif", "Times New Roman", serif;
			}

			* {
				box-sizing: border-box;
			}

			html,
			body {
				margin: 0;
				padding: 0;
				background: var(--bg);
				color: var(--ink);
				font-family: var(--mono);
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
				text-rendering: optimizeLegibility;
			}

			body {
				min-height: 100svh;
				overflow: hidden;
				position: relative;
			}

			.grain {
				position: fixed;
				inset: 0;
				pointer-events: none;
				z-index: 1;
				opacity: 0.28;
				mix-blend-mode: multiply;
				background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='240' height='240'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.08 0 0 0 0 0.13 0 0 0 0 0.10 0 0 0 0.55 0'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
			}

			.vignette {
				position: fixed;
				inset: 0;
				pointer-events: none;
				z-index: 2;
				background: radial-gradient(
					ellipse at center,
					transparent 55%,
					rgba(21, 32, 26, 0.08) 100%
				);
			}

			.frame {
				position: relative;
				z-index: 3;
				min-height: 100svh;
				display: grid;
				grid-template-rows: auto 1fr auto;
				padding: clamp(20px, 3.6vw, 40px);
				gap: clamp(40px, 8vh, 80px);
			}

			header,
			footer {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				gap: 24px;
				font-family: var(--mono);
				font-size: 11px;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--ink-soft);
			}

			footer {
				align-items: flex-end;
			}

			.tag {
				display: inline-flex;
				align-items: center;
				gap: 10px;
			}

			.tag .num {
				color: var(--ink);
				font-weight: 500;
			}

			.tag .sep {
				color: var(--ink-faint);
			}

			.dot {
				width: 7px;
				height: 7px;
				border-radius: 50%;
				background: var(--accent);
				box-shadow: 0 0 0 0 rgba(200, 70, 42, 0.6);
				animation: pulse 2.4s ease-out infinite;
			}

			@keyframes pulse {
				0% {
					box-shadow: 0 0 0 0 rgba(200, 70, 42, 0.55);
				}
				70% {
					box-shadow: 0 0 0 14px rgba(200, 70, 42, 0);
				}
				100% {
					box-shadow: 0 0 0 0 rgba(200, 70, 42, 0);
				}
			}

			main {
				display: flex;
				flex-direction: column;
				justify-content: center;
				gap: clamp(24px, 4vh, 40px);
				max-width: 22ch;
			}

			.eyebrow {
				font-family: var(--mono);
				font-size: 11px;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				color: var(--ink-soft);
				display: inline-flex;
				align-items: center;
				gap: 14px;
			}

			.eyebrow::before {
				content: "";
				width: 28px;
				height: 1px;
				background: var(--ink);
				display: inline-block;
			}

			.statement {
				font-family: var(--serif);
				font-weight: 400;
				font-style: italic;
				font-size: clamp(56px, 11vw, 148px);
				line-height: 0.92;
				letter-spacing: -0.02em;
				margin: 0;
				color: var(--ink);
			}

			.statement .line {
				display: block;
				opacity: 0;
				transform: translateY(14px);
				animation: rise 1s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
			}

			.statement .line:nth-child(1) {
				animation-delay: 0.15s;
			}

			.statement .line:nth-child(2) {
				animation-delay: 0.3s;
				padding-left: clamp(40px, 8vw, 120px);
			}

			.statement .line:nth-child(3) {
				animation-delay: 0.45s;
			}

			.statement em {
				font-style: italic;
				color: var(--accent);
			}

			.statement .amp {
				font-style: italic;
				color: var(--ink-faint);
			}

			@keyframes rise {
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			.lede {
				font-family: var(--mono);
				font-size: 13px;
				line-height: 1.6;
				color: var(--ink-soft);
				max-width: 38ch;
				opacity: 0;
				animation: fade 1.1s ease 0.7s forwards;
			}

			.lede a {
				color: var(--ink);
				text-decoration: none;
				border-bottom: 1px solid var(--ink-faint);
				padding-bottom: 1px;
				transition: border-color 0.2s ease;
			}

			.lede a:hover {
				border-color: var(--accent);
				color: var(--accent);
			}

			@keyframes fade {
				to {
					opacity: 1;
				}
			}

			.compass {
				display: flex;
				gap: 18px;
				align-items: center;
			}

			.compass .glyph {
				font-family: var(--serif);
				font-style: italic;
				font-size: 16px;
				color: var(--ink);
				text-transform: none;
				letter-spacing: 0;
			}

			@media (max-width: 720px) {
				body {
					overflow-y: auto;
					overflow-x: hidden;
				}

				.frame {
					gap: clamp(56px, 12vh, 96px);
					padding: 22px;
				}

				header,
				footer {
					flex-direction: column;
					gap: 14px;
					align-items: flex-start;
					font-size: 10px;
				}

				footer {
					align-items: flex-start;
				}

				main {
					max-width: none;
				}

				.statement {
					font-size: clamp(48px, 16vw, 96px);
				}

				.statement .line:nth-child(2) {
					padding-left: clamp(24px, 10vw, 48px);
				}

				.lede {
					font-size: 12px;
				}
			}

			@media (prefers-reduced-motion: reduce) {
				.statement .line,
				.lede {
					opacity: 1;
					transform: none;
					animation: none;
				}

				.dot {
					animation: none;
				}
			}
		</style>
	</head>
	<body>
		<div class="grain"></div>
		<div class="vignette"></div>

		<div class="frame">
			<header>
				<span class="tag">
					<span class="num">A.P.</span>
					<span class="sep">/</span>
					<span>Portfolio</span>
				</span>
				<span class="tag">
					<span>Edition</span>
					<span class="sep">—</span>
					<span class="num">N°02</span>
				</span>
			</header>

			<main>
				<span class="eyebrow">Status — In progress</span>
				<h1 class="statement">
					<span class="line">Currently</span>
					<span class="line"><em>building</em></span>
					<span class="line">something new.</span>
				</h1>
				<p class="lede">
					A new portfolio is taking shape. Until it lands, you can reach me at
					<a href="mailto:hello@alexperronnet.com">hello@alexperronnet.com</a>.
				</p>
			</main>

			<footer>
				<span class="tag">
					<span class="dot" aria-hidden="true"></span>
					<span>Online — Building</span>
				</span>
				<span class="compass">
					<span>Paris, FR</span>
					<span class="glyph">·</span>
					<span>MMXXVI</span>
				</span>
			</footer>
		</div>
	</body>
</html>
